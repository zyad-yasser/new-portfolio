{
  "name": "zyad-yasser-portfolio",
  "version": "3.0.0",
  "description": "A new portfolio application built with NextJS",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.8.0"
  },
  "scripts": {
    "dev": "next",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "husky": {
    "hooks": {
      "prepare-commit-msg": "exec < /dev/tty && git cz --hook || true",
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "./src/**/*.{ts,js,jsx,tsx}": ["pnpm check:fix"]
  },
  "dependencies": {
    "@mui/material": "^6.1.6",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.0",
    "axios": "^1.7.7",
    "lodash": "^4.17.21",
    "next": "^16.0.0",
    "next-redux-wrapper": "^8.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "react-redux": "^9.1.2",
    "react-reveal": "^1.2.2",
    "redux": "^5.0.1",
    "sass": "^1.81.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.8.0"
}
